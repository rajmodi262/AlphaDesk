# ========================================
# AlphaDesk Environment Configuration
# ========================================

# Market Data WebSocket (Binance Public Streams)
NEXT_PUBLIC_WS_URL=wss://stream.binance.com:9443/ws

# Market Data REST API
NEXT_PUBLIC_API_BASE_URL=https://api.binance.com/api/v3

# App Configuration
NEXT_PUBLIC_APP_NAME=AlphaDesk
NEXT_PUBLIC_DEFAULT_THEME=dark
NEXT_PUBLIC_DEFAULT_SYMBOL=BTCUSDT
NEXT_PUBLIC_DEFAULT_INTERVAL=1h

# Rate Limiting
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=5000
NEXT_PUBLIC_API_RATE_LIMIT=1200
